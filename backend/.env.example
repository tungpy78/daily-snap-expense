# App Config
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:19006

# Database Config
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=dailysnap_expense
DATABASE_USER=root
DATABASE_PASSWORD=replace_with_database_password
DATABASE_DIALECT=mysql

# JWT Config
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Upload Config
UPLOAD_DIR=public/uploads
MAX_UPLOAD_SIZE_MB=5
PUBLIC_BASE_URL=http://localhost:5001/public/uploads

# Security / CORS Config
CORS_ORIGIN=*
